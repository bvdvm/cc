rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Otwarte na czytanie i zapis — wystarczające dla małej, prywatnej apki
    // dla dwóch osób. Link do projektu nie jest publicznie ogłaszany, więc
    // praktyczne ryzyko jest niskie, ale każdy, kto pozna Twój firebaseConfig,
    // technicznie mógłby zapisywać dane. Jeśli chcesz to zaostrzyć w przyszłości,
    // dodaj Firebase Authentication (np. anonimowe logowanie + wspólne hasło)
    // i zmień poniższe `if true` na `if request.auth != null`.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
